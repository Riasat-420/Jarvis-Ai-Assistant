# ============================================================
# JARVIS AI ASSISTANT — CONFIGURATION
# ============================================================
# Copy this file to .env and fill in your keys.
# All keys below are FREE — no credit card required.
# ============================================================

# === PRIMARY LLM: GROQ (FREE) ===
# Sign up at: https://console.groq.com (2 minutes, no card)
# Then: Settings → API Keys → Create
GROQ_API_KEY=gsk_your_key_here

# === BACKUP LLM: GOOGLE GEMINI (FREE, OPTIONAL) ===
# Get key at: https://aistudio.google.com/apikey
GEMINI_API_KEY=

# === VOICE SETTINGS ===
# Available voices (all free, all natural sounding):
#   en-GB-RyanNeural     — British male (classic Jarvis)
#   en-US-GuyNeural      — American male, deep
#   en-US-DavisNeural    — Calm, authoritative male
#   en-AU-WilliamNeural  — Australian male
JARVIS_VOICE=en-GB-RyanNeural

# Wake word to activate voice mode
WAKE_WORD=jarvis

# Whisper model size: tiny, base, small, medium
# tiny = fastest, least accurate | base = recommended | small = better but slower
WHISPER_MODEL=base

# === MODELS (advanced, usually don't change) ===
GROQ_MODEL=llama-3.3-70b-versatile
GROQ_FAST_MODEL=llama-3.1-8b-instant
